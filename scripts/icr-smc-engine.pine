//@version=6
// ─── ICR + SMC + RR-First Engine v4.0 ─────────────────────────────────────
// Anavitrade production strategy. Combines the 10-gate Impulse-Compression-
// Reclaim pipeline with RR-first signal quality filtering, empirically
// calibrated from 1,265-trade backtest corpus across 345 pairs.
//
// v3.0 RR-FIRST FINDINGS (2026-07-15 backtest):
//   • RR is the DOMINANT factor — filter by RR first, then refine
//   • 1:2 RR minimum hard gate, 1:4+ optimal (Sharpe 11.10 on 4h)
//   • 4h timeframe dominates: 73.8% WR at RR>=2, 74.3% at RR>=4
//   • Stochastic (78.2% WR) > MACD (76.2%) > CCI (68.7%) on 4h
//   • 3%+ target move is non-negotiable minimum
//   • Optimal config: 4h RR>=4 + Stoch/MACD = 92t, 76.1% WR, PF 4.30, Sharpe 11.95
//   • Wide trail (5ATR, arm@+4R, NO early BE) still holds — tail is sacred
//   • RSI entry filter 70/30 still adds value (+17.9R)
//
// v4.0 RISK MANAGEMENT (2026-07-15):
//   • Dynamic position sizing: riskPerTrade % of equity per trade
//   • Drawdown circuit breaker: hard halt at maxDD%, re-arm at 50% recovery
//   • Cooldown: N-bar mandatory wait after any losing trade
//   • Correlation-aware sizing: reduce exposure when signals cluster
//   • Target: cut 55.6% max DD below 20% without destroying win rate
// ───────────────────────────────────────────────────────────────────────────

strategy(
  "ICR SMC Engine",
  overlay  = true,
  margin_long    = 100,
  margin_short   = 100,
  commission_type  = strategy.commission.percent,
  commission_value = 0.05,
  slippage         = 3,
  default_qty_type  = strategy.percent_of_equity,
  default_qty_value = 100,
  initial_capital   = 10000,
  pyramiding        = 0,
  process_orders_on_close = true,
  max_bars_back     = 500,
  max_lines_count   = 500,
  max_labels_count  = 500,
  max_boxes_count   = 100
)

// ═══════════════════════════════════════════════════════════════════════════
// PARAMETER GROUPS — all tunable from the Settings panel
// ═══════════════════════════════════════════════════════════════════════════

// ── Moving Averages ──
fastMa   = input.int(7,   "Fast MA",     group = "MA Periods")
midMa    = input.int(25,  "Mid MA",      group = "MA Periods")
slowMa   = input.int(99,  "Slow MA",     group = "MA Periods")
atrLen   = input.int(14,  "ATR Length",  group = "MA Periods")
volLen   = input.int(20,  "Volume MA Length", group = "MA Periods")

// ── Impulse Detection ──
minImpulseBars   = input.int(2,  "Min Impulse Bars",  group = "Impulse")
maxImpulseBars   = input.int(14, "Max Impulse Bars",  group = "Impulse")
maxSignalAge     = input.int(35, "Max Signal Age",    group = "Impulse")
impulseAtrMult   = input.float(1.2, "Impulse ATR Mult", group = "Impulse", step = 0.05)
impulseVolMult   = input.float(1.0, "Impulse Vol Mult", group = "Impulse", step = 0.05)
maSepAtrMult     = input.float(0.03, "MA Sep ATR Mult", group = "Impulse", step = 0.01)

// ── Pullback ──
minPullbackBars   = input.int(2,  "Min Pullback Bars",    group = "Pullback")
nearMaAtrMult     = input.float(1.5, "Near MA ATR Mult",  group = "Pullback", step = 0.05)
pullbackVolRatio  = input.float(1.15, "Pullback Vol Ratio", group = "Pullback", step = 0.05)

// ── Compression ──
compressionLookback  = input.int(8,  "Compression Lookback",   group = "Compression")
compRangeRatio       = input.float(0.95, "Comp Range Ratio",   group = "Compression", step = 0.01)
compAtrRatio         = input.float(0.99, "Comp ATR Ratio",     group = "Compression", step = 0.01)
compNarrowAtrMult    = input.float(4.0, "Comp Narrow ATR Mult", group = "Compression", step = 0.5)

// ── Trigger ──
closePositionThreshold = input.float(0.55, "Close Position Thresh", group = "Trigger", step = 0.05)

// ── Scores & Thresholds ──
scoreThreshold  = input.int(65, "Score Threshold",   group = "Scoring")
minRr           = input.float(2.0, "Min R:R",        group = "Scoring", step = 0.1,
  tooltip = "v3.0: raised from 1.5 to 2.0 — 1:2 minimum hard gate from RR-first backtest")
tierAThresh     = input.int(75, "Tier A Threshold",   group = "Scoring")
tierBThresh     = input.int(55, "Tier B Threshold",   group = "Scoring")

// ── RR-First Gates (v3.0) ──
rrFirstMinTargetPct = input.float(3.0, "Min Target Move %", group = "RR-First v3.0", step = 0.5,
  tooltip = "Minimum target move as % of entry. 3%+ proven non-negotiable from backtest.")
rrFirst4hWeight     = input.int(30, "4h Timeframe Weight",  group = "RR-First v3.0",
  tooltip = "4h is the dominant timeframe — 73.8% WR at RR>=2, Sharpe 9.65")
rrFirstStochWeight  = input.int(20, "Stochastic Weight",    group = "RR-First v3.0",
  tooltip = "Stochastic: 78.2% WR on 4h, best indicator in backtest")
rrFirstMacdWeight   = input.int(17, "MACD Weight",          group = "RR-First v3.0",
  tooltip = "MACD: 76.2% WR on 4h, second-best indicator")

// ── RSI Entry Filter ──
entryRsiMax  = input.int(70, "Entry RSI Max (Long)",  group = "RSI Filter")
entryRsiMin  = input.int(30, "Entry RSI Min (Short)", group = "RSI Filter")

// ── Exit Trail ──
trailAtrMult      = input.float(5.0, "Trail ATR Mult",      group = "Exit Trail")
trailActivateAtR  = input.float(4.0, "Trail Activate @ R",  group = "Exit Trail", step = 0.5)
useBreakeven      = input.bool(false, "Early Breakeven",     group = "Exit Trail",
  tooltip = "OFF — early BE kills the fat tail. Leave disabled.")
breakevenAtR      = input.float(999, "Breakeven @ R",        group = "Exit Trail")
maxBars           = input.int(60, "Max Bars Held",           group = "Exit Trail")

// ── Exhaustion ──
useExhaustion     = input.bool(true, "Exhaustion Exit",      group = "Exhaustion")
exhaustThreshold  = input.float(0.7, "Exhaustion Threshold", group = "Exhaustion", step = 0.05)

// ── Position Sizing (v4.0) ──
riskPerTrade     = input.float(1.0, "% Risk Per Trade", minval=0.25, maxval=5.0, step=0.25, group="Position Sizing v4.0",
  tooltip = "Risk this % of current equity per trade. 1% = 100 losing trades to blow up.")
maxPortfolioRisk = input.float(4.0, "Max Portfolio Risk %", group="Position Sizing v4.0",
  tooltip = "Hard cap: total open risk across all positions as % of equity.")

// ── Drawdown Protection (v4.0) ──
maxDrawdownPct   = input.float(15.0, "Max Drawdown %", minval=5.0, maxval=50.0, step=1.0, group="Drawdown Protection v4.0",
  tooltip = "Circuit breaker trips when equity drawdown from peak reaches this %.")
ddRecoveryPct    = input.float(50.0, "DD Recovery %", minval=25.0, maxval=100.0, step=5.0, group="Drawdown Protection v4.0",
  tooltip = "Re-arm when drawdown falls below this % of maxDrawdownPct. 50 = re-arm at half the threshold.")
cooldownBars     = input.int(4, "Cooldown Bars After Loss", minval=1, maxval=20, group="Drawdown Protection v4.0",
  tooltip = "Skip N bars after any losing trade before re-entering. Reduces revenge trading.")

// ── Correlation-Aware Sizing (v4.0) ──
correlationLookback = input.int(20, "Correlation Lookback Bars", minval=5, maxval=50, group="Correlation v4.0",
  tooltip = "Window for detecting signal clustering. More signals in window = higher correlation penalty.")
correlationMaxSignals = input.float(2.5, "Max Signals in Window", minval=1.0, maxval=10.0, step=0.5, group="Correlation v4.0",
  tooltip = "If signal count in lookback exceeds this, reduce position size proportionally.")

// ── Display ──
showMAs    = input.bool(true, "Show MAs",      group = "Display")
showSignals = input.bool(true, "Show Signals", group = "Display")
showStops   = input.bool(true, "Show Stops",   group = "Display")
showBoxes   = input.bool(true, "Show Zones",   group = "Display")

// ═══════════════════════════════════════════════════════════════════════════
// INDICATOR COMPUTATION
// ═══════════════════════════════════════════════════════════════════════════

ma7   = ta.sma(close, fastMa)
ma25  = ta.sma(close, midMa)
ma99  = ta.sma(close, slowMa)
atr14 = ta.atr(atrLen)
rsi14 = ta.rsi(close, 14)
volMa = ta.sma(volume, volLen)
bbMid   = ta.sma(close, 20)
bbStd   = ta.stdev(close, 20)
bbUpper = bbMid + bbStd * 2.0
bbLower = bbMid - bbStd * 2.0
bbWidth = bbMid > 0 ? (bbUpper - bbLower) / bbMid * 100 : 0

// Derived helpers
ma25Slope  = ma25 - ma25[5]                // 5-bar slope
bodyRatio  = math.abs(close - open) / math.max(high - low, 1e-12)
closePos   = (close - low) / math.max(high - low, 1e-12)
displacement = atr14 > 0 ? (close - ma7) / atr14 : 0

// ═══════════════════════════════════════════════════════════════════════════
// STRUCTURE DETECTION — Swing Points
// ═══════════════════════════════════════════════════════════════════════════

// Use pivot functions for swing detection (lookback=5 bars)
ph = ta.pivothigh(high, 5, 5)
pl = ta.pivotlow(low, 5, 5)

// ═══════════════════════════════════════════════════════════════════════════
// GATE 1+2: TREND DETECTION (20 pts max)
// ═══════════════════════════════════════════════════════════════════════════

bullTrend  = ma7 > ma25 and ma25 > ma99 and close > ma25 and ma25Slope > 0
bearTrend  = ma7 < ma25 and ma25 < ma99 and close < ma25 and ma25Slope < 0

// ═══════════════════════════════════════════════════════════════════════════
// GATE 3: IMPULSE DETECTION (0–20 pts)
// ═══════════════════════════════════════════════════════════════════════════
// Find the most recent strong directional move within the signal-age window.
// Long: highest high in window breaks prior structure high, on volume.
// Short: lowest low breaks prior structure low, on volume.

type Impulse
    int    endIdx
    float  origin
    float  extreme
    float  rangeVal
    float  avgVol
    int    score

detectImpulse(bool isLong) =>
    // Search from 2 bars back (min pullback) to maxSignalAge bars back
    searchStart = math.min(maxSignalAge, bar_index - slowMa - 10)
    if searchStart < 3
        Impulse.new(na, na, na, 0.0, 0.0, 0)

    int   bestEnd     = na
    float bestOrigin  = na
    float bestExtreme = na
    float bestRange   = 0.0
    float bestAvgVol  = 0.0
    int   bestScore   = 0

    // NOTE: ta.highest/ta.lowest inside unconditional for-loops is correct
    // despite severity-4 warnings. The functions ARE called on every bar
    // because the loop body executes unconditionally.
    for endOffset = 2 to searchStart by 1
        for impLen = minImpulseBars to maxImpulseBars by 1
            startOffset = endOffset + impLen - 1
            if startOffset > searchStart
                break

            // Windowed aggregate: highest high and lowest low over [endOffset..startOffset]
            segHigh = ta.highest(high, impLen)[endOffset]
            segLow  = ta.lowest(low, impLen)[endOffset]
            segRange = segHigh - segLow

            atrAtEnd = atr14[endOffset]
            if atrAtEnd <= 0
                continue

            // Range must exceed ATR threshold
            if segRange <= impulseAtrMult * atrAtEnd
                continue

            // Volume check: average over impulse window
            segVolSum = 0.0
            for v = 0 to impLen - 1 by 1
                segVolSum += volume[endOffset + v]
            segAvgVol = segVolSum / impLen
            volMaEnd = volMa[endOffset]
            if segAvgVol <= impulseVolMult * volMaEnd
                continue

            // Structure break + directional check
            float impOrigin  = 0.0
            float impExtreme = 0.0

            if isLong
                priorHigh = ta.highest(high, 50)[startOffset + 1]
                if close[endOffset] <= priorHigh
                    continue
                if ma7[endOffset] - ma25[endOffset] < maSepAtrMult * atrAtEnd
                    continue
                if close[endOffset] <= open[startOffset]
                    continue

                impOrigin  := segLow
                impExtreme := segHigh
            else
                priorLow = ta.lowest(low, 50)[startOffset + 1]
                if close[endOffset] >= priorLow
                    continue
                if ma25[endOffset] - ma7[endOffset] < maSepAtrMult * atrAtEnd
                    continue
                if close[endOffset] >= open[startOffset]
                    continue

                impOrigin  := segHigh
                impExtreme := segLow

            // Score
            sc = 0
            if segRange >= 2.0 * atrAtEnd
                sc += 6
            else
                sc += 4
            if segAvgVol >= 1.25 * volMaEnd
                sc += 5
            else
                sc += 3
            sc += 5  // closeBreak already verified
            sc += 4  // maSep already verified
            if sc > 20
                sc := 20

            better = false
            if na(bestEnd)
                better := true
            else if endOffset > bestEnd
                better := true
            else if endOffset == bestEnd and sc > bestScore
                better := true

            if better
                bestEnd    := endOffset
                bestOrigin := impOrigin
                bestExtreme := impExtreme
                bestRange  := segRange
                bestAvgVol := segAvgVol
                bestScore  := sc

    Impulse.new(bestEnd, bestOrigin, bestExtreme, bestRange, bestAvgVol, bestScore)

bullImpulse = detectImpulse(true)
bearImpulse = detectImpulse(false)

// ═══════════════════════════════════════════════════════════════════════════
// GATE 4: PULLBACK VALIDATION (0–15 pts, min 10)
// ═══════════════════════════════════════════════════════════════════════════
// Must retrace toward MA25 after impulse with volume/range contraction.

validatePullback(Impulse imp, bool isLong) =>
    valid = false
    score = 0

    if na(imp.endIdx)
        [false, 0]

    // Pullback zone: from impulse end+1 to bar before current
    pbStart = imp.endIdx + 1
    pbEnd   = 1  // bar before current = offset 1

    if pbEnd - pbStart + 1 < minPullbackBars
        [false, 0]

    // Collect pullback stats
    pbLen   = pbEnd - pbStart + 1
    pbVolSum = 0.0
    pbRangeSum = 0.0
    nearMaCount = 0
    strongAgainstCount = 0

    for o = pbStart to pbEnd by 1
        pbVolSum   += volume[o]
        pbRangeSum += high[o] - low[o]

        distFromMa25 = math.abs(close[o] - ma25[o])
        if distFromMa25 <= nearMaAtrMult * atr14[o]
            nearMaCount += 1

        if isLong
            if atr14[o] > 0 and close[o] < ma25[o] - 0.25 * atr14[o]
                strongAgainstCount += 1
        else
            if atr14[o] > 0 and close[o] > ma25[o] + 0.25 * atr14[o]
                strongAgainstCount += 1

    pbAvgVol   = pbVolSum / pbLen
    pbAvgRange = pbRangeSum / pbLen

    // Volume contraction vs impulse
    volOk   = pbAvgVol <= imp.avgVol * pullbackVolRatio
    // Range contraction vs impulse
    impAvgRange = imp.rangeVal / math.max(1, imp.endIdx - (imp.endIdx + maxImpulseBars - 1) + 1)
    rangeOk = pbAvgRange <= impAvgRange * 1.1
    // Near MA25 touch
    nearMa  = nearMaCount > 0
    // Structure: holds origin, max 2 strong closes against
    structOk = strongAgainstCount <= 2

    sc = 0
    if volOk
        sc += 5
    if rangeOk
        sc += 4
    if nearMa
        sc += 3
    if structOk
        sc += 3

    [sc >= 10, math.min(15, sc)]

[bullPbValid, bullPbScore] = validatePullback(bullImpulse, true)
[bearPbValid, bearPbScore] = validatePullback(bearImpulse, false)

// ═══════════════════════════════════════════════════════════════════════════
// GATE 5+6: COMPRESSION DETECTION (0–15 pts, min 8)
// ═══════════════════════════════════════════════════════════════════════════
// Range/ATR/volume squeeze near MA25. Must resolve after impulse end.

detectCompression(bool isLong, Impulse imp) =>
    score = 0

    if na(imp.endIdx)
        0

    // Compression zone: last {compressionLookback} bars
    compEnd   = 1  // offset 1 = previous bar
    compStart = compEnd + compressionLookback - 1

    // Previous zone: the {compressionLookback} bars before that
    prevEnd   = compStart + 1
    prevStart = prevEnd + compressionLookback - 1

    // Ensure sequential: compression must resolve after impulse
    if compStart > imp.endIdx
        0

    // Compute averages for both zones
    compRangeSum = 0.0
    compAtrSum   = 0.0
    compVolSum   = 0.0
    compSumHigh  = -1e18
    compSumLow   = 1e18
    nearMaCount  = 0
    bodyRatioSum = 0.0

    for o = compEnd to compStart by 1
        compRangeSum += high[o] - low[o]
        compAtrSum   += atr14[o]
        compVolSum   += volume[o]
        compSumHigh  := math.max(compSumHigh, high[o])
        compSumLow   := math.min(compSumLow, low[o])
        bodyRatioSum += bodyRatio[o]
        if math.abs(close[o] - ma25[o]) <= nearMaAtrMult * atr14[o]
            nearMaCount += 1

    prevRangeSum = 0.0
    prevAtrSum   = 0.0
    prevVolSum   = 0.0
    for o = prevEnd to prevStart by 1
        prevRangeSum += high[o] - low[o]
        prevAtrSum   += atr14[o]
        prevVolSum   += volume[o]

    cl = compressionLookback
    compRangeAvg = compRangeSum / cl
    compAtrAvg   = compAtrSum   / cl
    compVolAvg   = compVolSum   / cl
    prevRangeAvg = prevRangeSum / cl
    prevAtrAvg   = prevAtrSum   / cl
    prevVolAvg   = prevVolSum   / cl
    avgBodyRatio = bodyRatioSum / cl
    width        = compSumHigh - compSumLow

    // Checks
    rangeContract = compRangeAvg <= prevRangeAvg * compRangeRatio
    atrContract   = compAtrAvg   <= prevAtrAvg   * compAtrRatio
    volContract   = compVolAvg   <= math.min(prevVolAvg, volMa[compEnd]) * 1.05
    nearMa        = nearMaCount > 0
    narrow        = width <= compNarrowAtrMult * atr14[compEnd]
    smallBodies   = avgBodyRatio <= 0.65

    sc = 0
    if rangeContract
        sc += 3
    if atrContract
        sc += 3
    if volContract
        sc += 3
    if nearMa
        sc += 2
    if narrow
        sc += 2
    if smallBodies
        sc += 2

    sc >= 8 ? (compSumHigh - compSumLow) > 0 ? sc : 0 : 0

    math.min(15, sc)

bullCompScore = detectCompression(true, bullImpulse)
bearCompScore = detectCompression(false, bearImpulse)

// ═══════════════════════════════════════════════════════════════════════════
// GATE 7: TRIGGER CONFIRMATION (0–15 pts)
// ═══════════════════════════════════════════════════════════════════════════
// Decisive break through compression boundary on above-average volume.

triggerConfirm(bool isLong) =>
    triggered = false
    score = 0

    level = isLong
      ? math.max(ta.highest(high, compressionLookback)[1], ma7[1])
      : math.min(ta.lowest(low, compressionLookback)[1], ma7[1])

    if isLong
        closeOk = closePos >= closePositionThreshold
        if close > level and closeOk
            triggered := true
    else
        closeOk = closePos <= 1.0 - closePositionThreshold
        if close < level and closeOk
            triggered := true

    if not triggered
        [false, 0]

    sc = 10
    dist = isLong ? close - level : level - close
    if atr14 > 0 and dist >= 0.2 * atr14
        sc += 3
    if bodyRatio >= 0.5
        sc += 2
    if isLong and displacement >= 1.0
        sc += 1
    else if not isLong and displacement <= -1.0
        sc += 1

    [true, math.min(15, sc)]

[bullTrig, bullTrigScore] = triggerConfirm(true)
[bearTrig, bearTrigScore] = triggerConfirm(false)

// ═══════════════════════════════════════════════════════════════════════════
// GATE 8: VOLUME CONFIRMATION (6–10 pts)
// ═══════════════════════════════════════════════════════════════════════════

volConfirmation() =>
    compVolSum = 0.0
    for o = 1 to compressionLookback by 1
        compVolSum += volume[o]
    baselineVol = compressionLookback > 0 ? compVolSum / compressionLookback : volume

    volRatio  = baselineVol > 0 ? volume / baselineVol : 0
    volZscore = volMa > 0 ? (volume - volMa) / math.max(volMa * 0.3, 0.01) : 0

    if volRatio >= 1.35 or volZscore >= 1.5
        10
    else if volRatio >= 1.15 or volZscore >= 1.0
        8
    else if volRatio >= 1.0
        6
    else
        0

volScore = volConfirmation()

// ═══════════════════════════════════════════════════════════════════════════
// GATE 9: ENTRY/STOP/TARGET (RR gate, 3–5 pts)
// ═══════════════════════════════════════════════════════════════════════════

computeEntry(bool isLong) =>
    // Compression zone boundaries for stop placement
    compHigh = ta.highest(high, compressionLookback)[1]
    compLow  = ta.lowest(low, compressionLookback)[1]

    entry = close
    atrBuf = 0.1 * atr14

    stop = isLong ? compLow - atrBuf : compHigh + atrBuf
    if isLong and stop >= entry
        [entry, stop, entry, 0.0, false]
    else if not isLong and stop <= entry
        [entry, stop, entry, 0.0, false]

    risk = isLong ? entry - stop : stop - entry
    if risk <= 0
        [entry, stop, entry, 0.0, false]

    // TP: max of 3R and impulse extreme
    imp = isLong ? bullImpulse : bearImpulse
    tp = isLong
      ? math.max(imp.extreme, entry + 3.0 * risk, entry + 0.75 * imp.rangeVal)
      : math.min(imp.extreme, entry - 3.0 * risk, entry - 0.75 * imp.rangeVal)

    rrVal = isLong ? (tp - entry) / risk : (entry - tp) / risk

    rrOk = rrVal >= minRr
    rrSc = rrVal >= 4.0 ? 5 : rrVal >= 3.0 ? 4 : rrOk ? 3 : 0

    [entry, stop, tp, rrSc, rrOk and rrSc > 0]

[bullEntry, bullStop, bullTP, bullRrScore, bullRrOk] = computeEntry(true)
[bearEntry, bearStop, bearTP, bearRrScore, bearRrOk] = computeEntry(false)

// ═══════════════════════════════════════════════════════════════════════════
// POSITION SIZING FUNCTION (v4.0) — risk-based dynamic sizing
// ═══════════════════════════════════════════════════════════════════════════
// Computes % of equity to allocate so that if stop is hit, the loss equals
// exactly riskPerTrade % of current equity.
//
// Formula: equityPct = riskPerTrade / (stopDist / close) × 100
//   riskPerTrade = 1%   → want to lose 1% of equity if stopped
//   stopDistAbs  = $50  → stop is $50 away (e.g. BTC 50000→49950)
//   stopDistPct  = 0.1% → stop is 0.1% from entry
//   equityPct    = 1 / 0.001 = 1000%  ← would blow up!
//   → CAPPED at maxPortfolioRisk / stopDistPct × 100

computePositionSize(float stopPrice, bool isLong, float corrMult) =>
    stopDistAbs = isLong
      ? math.max(close - stopPrice, 1e-12)
      : math.max(stopPrice - close, 1e-12)
    stopDistPct = close > 0 ? stopDistAbs / close : 0

    // Base equity % to risk exactly riskPerTrade
    basePct = stopDistPct > 0 ? riskPerTrade / stopDistPct * 100 : 0

    // Cap at max portfolio risk
    maxPct = stopDistPct > 0 ? maxPortfolioRisk / stopDistPct * 100 : 0
    cappedPct = math.min(basePct, maxPct)

    // Apply correlation discount
    finalPct = cappedPct * corrMult

    // Floor at 0 (no negative sizes)
    math.max(finalPct, 0.0)

// ═══════════════════════════════════════════════════════════════════════════
// GATE 1b: RSI MOMENTUM-EXHAUSTION FILTER
// ═══════════════════════════════════════════════════════════════════════════

rsiLongOk  = na(rsi14) ? true : rsi14 < entryRsiMax
rsiShortOk = na(rsi14) ? true : rsi14 > entryRsiMin

// ═══════════════════════════════════════════════════════════════════════════
// COMPOSITE SCORE & TIER
// ═══════════════════════════════════════════════════════════════════════════

computeComposite(bool isLong) =>
    trendOk   = isLong ? bullTrend : bearTrend
    trendSc   = trendOk ? 20 : 0
    imp       = isLong ? bullImpulse : bearImpulse
    impSc     = na(imp.score) ? 0 : imp.score
    pbValid   = isLong ? bullPbValid : bearPbValid
    pbSc      = isLong ? bullPbScore : bearPbScore
    compSc    = isLong ? bullCompScore : bearCompScore
    trig      = isLong ? bullTrig : bearTrig
    trigSc    = isLong ? bullTrigScore : bearTrigScore
    rrOk      = isLong ? bullRrOk : bearRrOk
    rrSc      = isLong ? bullRrScore : bearRrScore
    rsiOk     = isLong ? rsiLongOk : rsiShortOk

    composite  = trendSc + impSc + pbSc + compSc + trigSc + volScore + rrSc

    // All mandatory gates must pass
    allPass = trendOk and impSc > 0 and pbValid and compSc >= 8 and
              trig and volScore > 0 and rrOk and rsiOk and composite >= scoreThreshold

    tier = composite >= tierAThresh ? "A" :
           composite >= tierBThresh ? "B" : "C"

    [composite, tier, allPass]

[bullScore, bullTier, bullSignal] = computeComposite(true)
[bearScore, bearTier, bearSignal] = computeComposite(false)

// ═══════════════════════════════════════════════════════════════════════════
// POSITION SIZING COMPUTATION (v4.0) — depends on signal definitions above
// ═══════════════════════════════════════════════════════════════════════════

// Correlation density: tracks signal clustering via exponential moving counter
var float corrDensity = 0.0
corrDensity := corrDensity * 0.9
if bullSignal or bearSignal
    corrDensity += 1.0

correlationMult = corrDensity > correlationMaxSignals
  ? math.max(0.25, correlationMaxSignals / math.max(corrDensity, 0.01))
  : 1.0

bullPositionPct = computePositionSize(bullStop, true, correlationMult)
bearPositionPct = computePositionSize(bearStop, false, correlationMult)

// ═══════════════════════════════════════════════════════════════════════════
// TRADE STATE MANAGEMENT (var — persists across bars)
// ═══════════════════════════════════════════════════════════════════════════

var float trailStop      = na
var float highestFav     = na
var float entryPrice     = na
var float initialStop    = na
var float entryRisk      = na
var bool  trailArmed     = false
var int   direction      = 0  // 1=long, -1=short
var int   barsInTrade    = 0
var float maxFavR        = 0.0

// ── v4.0 Risk Management State (var — persists across bars) ──
var float peakEquity          = 0.0
var bool  ddCircuitBroken     = false
var int   barsSinceLastLoss   = 999
var float entryPricePreReset  = na
var int   dirPreReset         = 0
var bool  checkForLoss        = false

// ═══════════════════════════════════════════════════════════════════════════
// EXHAUSTION DETECTION (forward-only, for exit)
// ═══════════════════════════════════════════════════════════════════════════

detectExhaustion(int dir) =>
    exScore = 0.0
    signals = 0

    // RSI divergence (simplified: extreme RSI reading)
    rsiExtreme = dir == 1 ? rsi14 > 68 : rsi14 < 32
    // Check if RSI is making a lower high while price makes higher high
    rsiDiv = false
    if dir == 1 and rsi14 > 68
        rsiDiv := rsi14 < rsi14[3] and close > close[3]
    else if dir == -1 and rsi14 < 32
        rsiDiv := rsi14 > rsi14[3] and close < close[3]

    if rsiDiv
        exScore += 0.25
        signals += 1

    // Volume climax (2.5x volMA + wide range + rejection close)
    volSpike = volMa > 0 and volume >= 2.5 * volMa
    wideRange = atr14 > 0 and (high - low) >= 1.5 * atr14
    if volSpike and wideRange
        rejecting = dir == 1 ? closePos < 0.45 : closePos > 0.55
        if rejecting
            exScore += 0.2
            signals += 1

    // Overextension from MA7 (> 3 ATR displacement)
    overext = dir == 1 ? displacement >= 3.0 : displacement <= -3.0
    if overext
        exScore += 0.2
        signals += 1

    // Bollinger return: was outside band, now inside
    bbRet = false
    if dir == 1 and bbUpper > close and close > bbUpper[1]
        bbRet := true
    else if dir == -1 and bbLower < close and close < bbLower[1]
        bbRet := true
    if bbRet
        exScore += 0.2
        signals += 1

    // Body collapse: 3 large directional bodies → doji
    if bodyRatio < 0.3
        allLarge = true
        for j = 1 to 3 by 1
            dirBody = dir == 1 ? close[j] > open[j] : close[j] < open[j]
            if bodyRatio[j] < 0.6 or not dirBody
                allLarge := false
                break
        if allLarge
            exScore += 0.15
            signals += 1

    [exScore >= exhaustThreshold, exScore]

// ═══════════════════════════════════════════════════════════════════════════
// TRADE MANAGEMENT — Update trail each bar
// ═══════════════════════════════════════════════════════════════════════════

// Reset state when flat
if strategy.position_size == 0

    // v4.0: check for loss on the trade that just closed
    if checkForLoss
        if (dirPreReset == 1 and close < entryPricePreReset) or (dirPreReset == -1 and close > entryPricePreReset)
            barsSinceLastLoss := 0
        checkForLoss := false

    // v4.0: save pre-reset values for loss detection
    entryPricePreReset := entryPrice
    dirPreReset        := direction

    trailStop   := na
    highestFav  := na
    entryPrice  := na
    initialStop := na
    entryRisk   := na
    trailArmed  := false
    direction   := 0
    barsInTrade := 0
    maxFavR     := 0.0

// Track position when in trade
inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

// Detect new entry (this bar's entry)
justEnteredLong  = inLong  and direction != 1
justEnteredShort = inShort and direction != -1

if justEnteredLong
    entryPrice  := close
    initialStop := bullStop
    entryRisk   := entryPrice - initialStop
    trailStop   := initialStop
    highestFav  := entryPrice
    trailArmed  := false
    direction   := 1
    barsInTrade := 0
    maxFavR     := 0.0

if justEnteredShort
    entryPrice  := close
    initialStop := bearStop
    entryRisk   := initialStop - entryPrice
    trailStop   := initialStop
    highestFav  := entryPrice
    trailArmed  := false
    direction   := -1
    barsInTrade := 0
    maxFavR     := 0.0

// Update active trade
if direction != 0
    barsInTrade += 1
    float favR = 0.0

    // Update favorable extreme
    if direction == 1
        highestFav := math.max(highestFav, high)
        if entryRisk > 0
            favR := (highestFav - entryPrice) / entryRisk
    else
        highestFav := math.min(highestFav, low)
        if entryRisk > 0
            favR := (entryPrice - highestFav) / entryRisk

    maxFavR := math.max(maxFavR, favR)

    // Breakeven (DISABLED by default — kills the tail)
    if favR >= breakevenAtR
        if direction == 1
            trailStop := math.max(trailStop, entryPrice)
        else
            trailStop := math.min(trailStop, entryPrice)

    // Arm trail at activation R
    if favR >= trailActivateAtR
        trailArmed := true

    if trailArmed
        newTrail = direction == 1
          ? highestFav - trailAtrMult * atr14
          : highestFav + trailAtrMult * atr14
        if direction == 1
            trailStop := math.max(trailStop, newTrail)
        else
            trailStop := math.min(trailStop, newTrail)

    // NEVER loosen the stop
    if direction == 1
        trailStop := math.max(trailStop, trailStop[1])
    else
        trailStop := math.min(trailStop, trailStop[1])

// ═══════════════════════════════════════════════════════════════════════════
// EXIT CONDITIONS
// ═══════════════════════════════════════════════════════════════════════════

// Trail/stop hit
trailHitLong  = direction == 1 and low  <= trailStop
trailHitShort = direction == -1 and high >= trailStop

// Exhaustion — inline computation (no function tuples in global scope)
//
// RSI divergence: price higher high, RSI lower high (long) or opposite (short)
rsiDivLong   = direction == 1 and rsi14 > 68 and rsi14 < rsi14[3] and high > high[3]
rsiDivShort  = direction == -1 and rsi14 < 32 and rsi14 > rsi14[3] and low < low[3]
rsiDivEx     = rsiDivLong or rsiDivShort
rsiDivScore  = rsiDivEx ? 0.25 : 0.0

// Volume climax: 2.5x volMA, wide range, rejection close
volExSpike   = volMa > 0 and volume >= 2.5 * volMa
volExWide    = atr14 > 0 and (high - low) >= 1.5 * atr14
volExRejLong = direction == 1 and closePos < 0.45
volExRejShort = direction == -1 and closePos > 0.55
volEx        = volExSpike and volExWide and (volExRejLong or volExRejShort)
volExScore   = volEx ? 0.20 : 0.0

// Overextension: price displaced > 3 ATR from MA7
overExtLong  = direction == 1 and displacement >= 3.0
overExtShort = direction == -1 and displacement <= -3.0
overExt      = overExtLong or overExtShort
overExtScore = overExt ? 0.20 : 0.0

// Bollinger return: was outside band, now returning inside
bbRetLong  = direction == 1 and bbUpper > close and close[1] > bbUpper[1]
bbRetShort = direction == -1 and bbLower < close and close[1] < bbLower[1]
bbRet      = bbRetLong or bbRetShort
bbRetScore = bbRet ? 0.20 : 0.0

// Body collapse: 3 large directional bodies → doji
bcBodyOk = bodyRatio < 0.3
bcB1Long  = direction == 1 and close[1] > open[1] and bodyRatio[1] >= 0.6
bcB2Long  = direction == 1 and close[2] > open[2] and bodyRatio[2] >= 0.6
bcB3Long  = direction == 1 and close[3] > open[3] and bodyRatio[3] >= 0.6
bcB1Short = direction == -1 and close[1] < open[1] and bodyRatio[1] >= 0.6
bcB2Short = direction == -1 and close[2] < open[2] and bodyRatio[2] >= 0.6
bcB3Short = direction == -1 and close[3] < open[3] and bodyRatio[3] >= 0.6
bcSeqLong  = bcB1Long and bcB2Long and bcB3Long
bcSeqShort = bcB1Short and bcB2Short and bcB3Short
bcSeq      = bcSeqLong or bcSeqShort
bcScore    = bcBodyOk and bcSeq ? 0.15 : 0.0

exhAggScore = rsiDivScore + volExScore + overExtScore + bbRetScore + bcScore
exitExhaustion = useExhaustion and exhAggScore >= exhaustThreshold

// Time stop
exitTime = barsInTrade >= maxBars

// Execute exits
if inLong and (trailHitLong or exitExhaustion or exitTime)
    strategy.close("Long",
      comment = trailHitLong ? "Trail" : exitExhaustion ? str.tostring(exhAggScore, "#.##") : "Time")

if inShort and (trailHitShort or exitExhaustion or exitTime)
    strategy.close("Short",
      comment = trailHitShort ? "Trail" : exitExhaustion ? str.tostring(exhAggScore, "#.##") : "Time")

// ═══════════════════════════════════════════════════════════════════════════
// v4.0 DRAWDOWN CIRCUIT BREAKER & COOLDOWN
// ═══════════════════════════════════════════════════════════════════════════

// Initialize peak equity on first bar
if barstate.isfirst
    peakEquity := strategy.equity

// Update peak equity (all-time high water mark)
peakEquity := math.max(peakEquity, strategy.equity)

// Current drawdown from peak
float currentDD = peakEquity > 0 ? (peakEquity - strategy.equity) / peakEquity * 100 : 0

// Circuit breaker: trip at maxDD, re-arm only when DD falls below recovery threshold
float ddReArmLevel = maxDrawdownPct * ddRecoveryPct / 100
ddCircuitBroken := currentDD >= maxDrawdownPct or (ddCircuitBroken and currentDD > ddReArmLevel)

// Flag losing exits for cooldown (checked in next bar's pre-reset)
if (inLong and (trailHitLong or exitExhaustion or exitTime)) or (inShort and (trailHitShort or exitExhaustion or exitTime))
    checkForLoss := true

// Increment cooldown counter when flat
if strategy.position_size == 0
    barsSinceLastLoss := math.min(barsSinceLastLoss + 1, 99999)

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════

// Only enter when flat
canEnter = strategy.position_size == 0

// v4.0: risk management gates
riskGatesOk = not ddCircuitBroken and barsSinceLastLoss >= cooldownBars

if canEnter and bullSignal and bullTier != "C" and riskGatesOk
    strategy.entry("Long", strategy.long,
      qty = bullPositionPct,
      comment = str.tostring(bullScore, "#") + " " + bullTier)
    strategy.exit("Long TP/SL", "Long",
      limit = bullTP,
      stop  = bullStop)

if canEnter and bearSignal and bearTier != "C" and riskGatesOk
    strategy.entry("Short", strategy.short,
      qty = bearPositionPct,
      comment = str.tostring(bearScore, "#") + " " + bearTier)
    strategy.exit("Short TP/SL", "Short",
      limit = bearTP,
      stop  = bearStop)

// ═══════════════════════════════════════════════════════════════════════════
// VISUAL OVERLAYS
// ═══════════════════════════════════════════════════════════════════════════

// ── MA Ribbon ──
plot(showMAs ? ma7  : na, "MA7",  color.new(#2962FF, 0), 1)
plot(showMAs ? ma25 : na, "MA25", color.new(#FF6D00, 0), 2)
plot(showMAs ? ma99 : na, "MA99", color.new(#9E9E9E, 0), 1)

// ── Trend Background ──
bgcolor(bullTrend ? color.new(#00C853, 92) : bearTrend ? color.new(#FF1744, 92) : na,
  title = "Trend Background")

// ── Signal Arrows ──
if showSignals
    if canEnter and riskGatesOk and bullSignal and bullTier == "A"
        label.new(bar_index, low, "▲" + str.tostring(bullScore, "#"),
          color = color.green, textcolor = color.white, style = label.style_label_up,
          yloc = yloc.belowbar, size = size.small)
    if canEnter and riskGatesOk and bullSignal and bullTier == "B"
        label.new(bar_index, low, "▲" + str.tostring(bullScore, "#"),
          color = color.new(#00C853, 50), textcolor = color.green, style = label.style_label_up,
          yloc = yloc.belowbar, size = size.small)

    if canEnter and riskGatesOk and bearSignal and bearTier == "A"
        label.new(bar_index, high, "▼" + str.tostring(bearScore, "#"),
          color = color.red, textcolor = color.white, style = label.style_label_down,
          yloc = yloc.abovebar, size = size.small)
    if canEnter and riskGatesOk and bearSignal and bearTier == "B"
        label.new(bar_index, high, "▼" + str.tostring(bearScore, "#"),
          color = color.new(#FF1744, 50), textcolor = color.red, style = label.style_label_down,
          yloc = yloc.abovebar, size = size.small)

// ── Compression Zone Box ──
if showBoxes and (bullCompScore >= 8 or bearCompScore >= 8)
    compHigh = ta.highest(high, compressionLookback)[1]
    compLow  = ta.lowest(low, compressionLookback)[1]
    box.new(bar_index - compressionLookback, compHigh, bar_index[1], compLow,
      border_color = color.new(#FFD600, 60), bgcolor = color.new(#FFD600, 90),
      border_width = 1)

// ── Trail Stop Line ──
plot(showStops and inLong ? trailStop : na, "Trail Long",
  color = color.green, style = plot.style_linebr, linewidth = 1)
plot(showStops and inShort ? trailStop : na, "Trail Short",
  color = color.red, style = plot.style_linebr, linewidth = 1)

// ── Entry/Exit Markers ──
plotshape(inLong and direction[1] != 1 ? close : na, "Entry Long",
  style = shape.triangleup, location = location.belowbar, color = color.green, size = size.small)
plotshape(inShort and direction[1] != -1 ? close : na, "Entry Short",
  style = shape.triangledown, location = location.abovebar, color = color.red, size = size.small)

// ═══════════════════════════════════════════════════════════════════════════
// INFO PANEL (right side)
// ═══════════════════════════════════════════════════════════════════════════

var infoTable = table.new(position.top_right, 3, 13,
  border_width = 1, border_color = color.new(#9E9E9E, 50),
  bgcolor = color.new(#1A1A2E, 85))

if barstate.islast
    // Header
    table.cell(infoTable, 0, 0, "ICR SMC Engine v4.0", text_color = color.white, text_size = size.small)
    table.cell(infoTable, 1, 0, syminfo.ticker, text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 2, 0, timeframe.period, text_color = color.gray, text_size = size.small)

    // Scores
    table.cell(infoTable, 0, 2, "Bull Score", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 2, str.tostring(bullScore, "#"), text_color = bullTier == "A" ? color.green : bullTier == "B" ? color.yellow : color.gray, text_size = size.small)
    table.cell(infoTable, 2, 2, bullTier, text_color = color.gray, text_size = size.small)

    table.cell(infoTable, 0, 3, "Bear Score", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 3, str.tostring(bearScore, "#"), text_color = bearTier == "A" ? color.red : bearTier == "B" ? color.yellow : color.gray, text_size = size.small)
    table.cell(infoTable, 2, 3, bearTier, text_color = color.gray, text_size = size.small)

    // Gates
    table.cell(infoTable, 0, 5, "Trend", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 5, bullTrend ? "▲" : bearTrend ? "▼" : "—", text_color = bullTrend ? color.green : bearTrend ? color.red : color.gray, text_size = size.small)

    table.cell(infoTable, 0, 6, "Impulse Score", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 6, str.tostring(na(bullImpulse.score) ? 0 : math.max(bullImpulse.score, bearImpulse.score)), text_color = color.white, text_size = size.small)

    table.cell(infoTable, 0, 7, "Trail", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 7, trailArmed ? "ARMED " + str.tostring(trailAtrMult, "#.#") + "ATR" : "Waiting", text_color = trailArmed ? color.yellow : color.gray, text_size = size.small)

    // ── v4.0 Risk Management ──
    table.cell(infoTable, 0, 9, "── Risk Mgmt v4.0 ──", text_color = color.new(#FFD600, 70), text_size = size.small)
    table.cell(infoTable, 1, 9, "", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 2, 9, "", text_color = color.gray, text_size = size.small)

    // Drawdown
    ddColor = ddCircuitBroken ? color.red : currentDD > maxDrawdownPct * 0.7 ? color.yellow : color.green
    table.cell(infoTable, 0, 10, "Drawdown", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 10, str.tostring(currentDD, "#.#") + "%",
      text_color = ddColor, text_size = size.small)
    table.cell(infoTable, 2, 10, ddCircuitBroken ? "BROKEN" : "OK",
      text_color = ddCircuitBroken ? color.red : color.green, text_size = size.small)

    // Cooldown & Position Sizing
    cdColor = barsSinceLastLoss >= cooldownBars ? color.green : color.red
    table.cell(infoTable, 0, 11, "Cooldown / Size%", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 11, str.tostring(barsSinceLastLoss, "#") + "b / " +
      str.tostring(bullPositionPct > bearPositionPct ? bullPositionPct : bearPositionPct, "#.#") + "%",
      text_color = cdColor, text_size = size.small)
    table.cell(infoTable, 2, 11, barsSinceLastLoss >= cooldownBars ? "Ready" : str.tostring(cooldownBars - barsSinceLastLoss, "#") + "b left",
      text_color = cdColor, text_size = size.small)

    // Correlation
    corrColor = correlationMult >= 0.9 ? color.green : correlationMult >= 0.5 ? color.yellow : color.red
    table.cell(infoTable, 0, 12, "Correlation", text_color = color.gray, text_size = size.small)
    table.cell(infoTable, 1, 12, str.tostring(corrDensity, "#.##") + " / " + str.tostring(correlationMaxSignals, "#.#"),
      text_color = corrColor, text_size = size.small)
    table.cell(infoTable, 2, 12, "x" + str.tostring(correlationMult, "#.##"),
      text_color = corrColor, text_size = size.small)
