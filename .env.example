VITE_WALLETCONNECT_PROJECT_ID=05dcea0e853d0ee47e980c540ec55494

# Automated signal-to-order dispatch is deny-by-default. Enable only after
# documented strategy validation and exchange testnet proof are complete.
AUTOMATED_SIGNAL_DISPATCH_ENABLED=false

# Set false only when immediate password-account access is an intentional policy.
REQUIRE_EMAIL_VERIFICATION=true

# Transactional authentication email. `AUTH_EMAIL` is the native Cloudflare
# Worker binding declared in wrangler.toml; configure EMAIL_FROM as a secret
# after its sending domain is verified. Resend remains a compatible fallback.
# AUTH_EMAIL is a Worker binding, not an environment variable.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Anavitrade <auth@your-verified-domain.example>

# Aster DEX execution
ASTER_API_BASE_URL=https://fapi.asterdex.com
ASTER_BUILDER_ADDRESS=0xYourRegisteredAsterBuilderAddress
ASTER_DEFAULT_FEE_RATE=0
ASTER_ENVIRONMENT=production
# Keep false until Aster order payload signing and fill sync are verified.
ASTER_LIVE_ORDER_SUBMISSION_ENABLED=false
# Required whenever live Aster order submission is enabled. Keep this at the
# approved tester ceiling until a separate production risk decision is made.
ASTER_MAX_ORDER_NOTIONAL_USD=100

# PancakeSwap DEX execution (BSC). Addresses below are PancakeSwap's OWN Permit2
# and Universal Router deployments — NOT Uniswap's canonical Permit2 address.
# Re-verify on BscScan before ever setting live submission to true.
PANCAKESWAP_RPC_URL=https://bsc-dataseed.binance.org
PANCAKESWAP_PERMIT2_ADDRESS=0x31c2F6fcFf4F8759b3Bd5Bf0e1084A055615c768
PANCAKESWAP_UNIVERSAL_ROUTER_ADDRESS=0xd9C500DfF816a1Da21A48A732d3498Bf09dc9AEB
PANCAKESWAP_EXECUTOR_ADDRESS=0xYourPancakeswapExecutorAddress
PANCAKESWAP_EXECUTOR_PRIVATE_KEY=0xYourPancakeswapExecutorPrivateKey
PANCAKESWAP_ENVIRONMENT=production
# Keep false until Permit2 delegation flow, quoting, and swap submission are verified.
PANCAKESWAP_LIVE_ORDER_SUBMISSION_ENABLED=false

# Encryption key for API credentials at rest (AES-256).
# Must be set separately from JWT_SECRET.
# In production, use `npx wrangler secret put ENCRYPTION_KEY`.
# Choose a unique 32+ character key.
ENCRYPTION_KEY=your-encryption-key-here

# Anthropic API key for the Opus trade-judgment gate (step 5 of the shared
# dispatch gate, src/server/analysis/llm-trade-judge.ts). Required for any
# TradeIntent, from any source, to pass live dispatch — without it every
# intent fails closed at "ml_unreachable" (R1.3), same as a missing
# statistical model before it. In production, use
# `npx wrangler secret put ANTHROPIC_API_KEY`.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
