# Anavitrade Execution Server — Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Worker base URL (Cloudflare Worker, or dev: http://localhost:5174)
WORKER_URL=https://anavitrade-trading.workers.dev

# Shared secret for VPS-to-Worker auth — match INTERNAL_SECRET in wrangler secrets
INTERNAL_SECRET=openssl-rand-hex-32

# AES-256-GCM key — MUST match Worker's ENCRYPTION_KEY
ENCRYPTION_KEY=replace-with-production-key

# Server configuration
PORT=9090
POLL_INTERVAL_MS=5000
EXECUTION_MODE=testnet

# Grafana admin credentials (grafana container reads these)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace-with-strong-password
